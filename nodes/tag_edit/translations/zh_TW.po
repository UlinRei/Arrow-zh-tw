msgid "Tag Edit"
msgstr "編輯標籤"

msgid "TAG_EDIT_INSPECTOR_FIELD_CHARACTER"
msgstr "角色"

msgid "TAG_EDIT_INSPECTOR_APPLY_GLOBAL_CHAR_FILTERS_TOOLTIP"
msgstr "套用角色屬性面板中設定的全域篩選條件。目前節點使用的角色一定會列出。"

msgid "TAG_EDIT_INSPECTOR_FIELD_EDIT"
